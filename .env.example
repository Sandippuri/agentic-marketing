SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
# Mirror to NEXT_PUBLIC_* so the browser client (login form, realtime) sees them.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Internal Control-Plane auth ---
# Shared secret OpenClaw processes use to call apps/web Route Handlers.
INTERNAL_API_TOKEN=

# Comma-separated list of email domains (or full emails) allowed to sign in.
# /auth/callback rejects anyone outside this list. Required.
AUTH_ALLOWLIST=venture23.io,ibriz.com

# --- Redis (Upstash) ---
REDIS_URL=

# --- LLM ---
ANTHROPIC_API_KEY=

# --- Slack / Discord ---
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=

# --- Adapters (filled per phase) ---
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORG_URN=
X_CLIENT_ID=
X_CLIENT_SECRET=
X_ACCESS_TOKEN=
HUBSPOT_ACCESS_TOKEN=
MAILCHIMP_API_KEY=
GA4_PROPERTY_ID=

# --- Asset generation ---
