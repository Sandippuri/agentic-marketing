# --- Supabase ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
# Mirror to NEXT_PUBLIC_* so the browser client (login form, realtime) sees them.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Internal Control-Plane auth ---
# Shared secret OpenClaw processes use to call apps/web Route Handlers.
INTERNAL_API_TOKEN=

# --- Service base URLs (used for inter-service calls) ---
# Manager HTTP server (Control Plane forwards thread notifications here)
MANAGER_BASE_URL=http://manager:3001
# Distributor HTTP server (Control Plane enqueues embeddings here)
DISTRIBUTOR_BASE_URL=http://distributor:4002
# Control Plane base URL (Manager + Distributor call API routes here)
CP_BASE_URL=http://localhost:3000

# Comma-separated list of email domains (or full emails) allowed to sign in.
# /auth/callback rejects anyone outside this list. Required.
AUTH_ALLOWLIST=venture23.io,ibriz.com

# --- Redis (Upstash) ---
REDIS_URL=

# --- LLM ---
ANTHROPIC_API_KEY=

# --- Slack / Discord ---
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=

# --- Adapters (filled per phase) ---
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORG_URN=
X_API_KEY=
X_API_KEY_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
HUBSPOT_ACCESS_TOKEN=
MAILCHIMP_API_KEY=
# Mailchimp datacenter shard (e.g. "us1" from API key after the dash)
MAILCHIMP_DC=
# HubSpot list/segment ID to send to
HUBSPOT_LIST_ID=
# Mailchimp audience ID
MAILCHIMP_AUDIENCE_ID=
GA4_PROPERTY_ID=
# Full GCP service-account JSON (base64-encoded or raw JSON string)
GA4_SERVICE_ACCOUNT_JSON=

# --- Asset generation ---
REPLICATE_API_TOKEN=
BANNERBEAR_API_KEY=
# Placid API token (alternative to Bannerbear)
PLACID_API_TOKEN=

# --- Learning loop (Phase 11) ---
OPENAI_API_KEY=
# Supabase Storage bucket for assets
SUPABASE_STORAGE_BUCKET=assets

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
# Service name sent in OTLP traces
OTEL_SERVICE_NAME=marketing-agent

# --- Reporting ---
# Slack channel ID for weekly Analyst cron reports
MARKETING_SLACK_CHANNEL_ID=
