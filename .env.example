# =============================================================================
# Marketing Agent — Environment variables
# =============================================================================
# Tiers:
#   [BOOT]    Required for the system to start at all (web + manager + distributor)
#   [CHAT]    Required to receive @marketing mentions (pick Slack and/or Discord)
#   [LLM]     Required for any agent reasoning
#   [RAG]     Required for findSimilarContent / findBrandGuidance / findCommonMistakes
#   [CHANNEL] Required only for the channel you publish to
#   [OPS]     Optional: observability, scheduled reports, dev quality-of-life
#
# See RUNBOOK.md → "First-launch checklist" for the minimum subset to copy.
# =============================================================================


# --- [BOOT] Supabase --------------------------------------------------------
# From Supabase dashboard → Settings → API.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Connection string from Supabase → Settings → Database → Connection string (URI).
DATABASE_URL=
# Mirror for the browser client (login form, realtime).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Comma-separated list of email domains (or full emails) allowed to sign in.
# /auth/callback rejects anyone outside this list.
AUTH_ALLOWLIST=venture23.io,ibriz.com

# Supabase Storage bucket used for assets (must exist; create in Supabase Storage).
SUPABASE_STORAGE_BUCKET=assets


# --- [BOOT] Internal Control-Plane auth -------------------------------------
# Shared secret OpenClaw processes use to call apps/web Route Handlers.
# Generate with: openssl rand -hex 32
INTERNAL_API_TOKEN=


# --- [BOOT] Service base URLs (inter-service calls) -------------------------
# Manager HTTP server (Control Plane forwards thread notifications here).
MANAGER_BASE_URL=http://manager:3001
MANAGER_HTTP_PORT=3001
# Distributor HTTP server (Control Plane enqueues embeddings here).
DISTRIBUTOR_BASE_URL=http://distributor:4002
EMBED_HTTP_PORT=4002
# Control Plane base URL (Manager + Distributor call API routes here).
CP_BASE_URL=http://localhost:3000


# --- [BOOT] Redis (Upstash) -------------------------------------------------
# rediss://default:<password>@<host>:<port>  — Upstash → Database → REST.
# Required while BullMQ (apps/distributor) is still running. Optional once
# the migration to Vercel Workflow is complete; the in-process chat history
# falls back to memory but production should keep Redis (or Upstash) for
# durability. See VERCEL-MIGRATION-PLAN §13.
REDIS_URL=


# --- [BOOT/MIGRATION] Vercel Workflow feature flags -------------------------
# Phases 1–3 of the BullMQ → Vercel Workflow migration ship behind these
# flags so legacy and workflow paths can run in parallel. Flip per-env once
# you've drained the BullMQ queues. See VERCEL-MIGRATION-PLAN §11–§13.
#   1 = use Vercel Workflow path
#   unset / 0 = use legacy BullMQ / manager path
WORKFLOW_PUBLISH=
WORKFLOW_EMBED=
WORKFLOW_CHAT=

# Optional bearer token for /api/cron/* routes. Vercel Cron sends it as
# `Authorization: Bearer <CRON_SECRET>`. Unset = no auth (fine for local).
CRON_SECRET=


# --- [LLM] Anthropic --------------------------------------------------------
# Required by every sub-agent (Strategist, Content, Analyst, Asset, Orchestrator).
ANTHROPIC_API_KEY=

# --- [LLM + IMAGE + VIDEO] Google Gemini ------------------------------------
# Powers three things:
#   1. Gemini LLM models in the /test-chat dropdown.
#   2. Native Nano Banana / Nano Banana 2 image generation (default
#      image_model="nano-banana-2"). When unset, image gen falls back to
#      Replicate-hosted nano-banana / SDXL / Flux (REPLICATE_API_TOKEN below).
#   3. Veo 3.1 promotional video generation for LinkedIn / X posts. Toggle
#      on via Settings → "Enable promotional video generation".
GEMINI_API_KEY=


# --- [RAG] OpenAI ----------------------------------------------------------
# Optional now: embeddings default to Gemini (see EMBEDDING_PROVIDER below).
# Set this only if you want OpenAI as the embedding provider, want GPT-* in
# the /test-chat dropdown, or want the "GPT Image 1 (ChatGPT)" option in
# Settings → Image generation model. Org must have gpt-image-1 access for
# the image option to work.
OPENAI_API_KEY=


# --- [RAG] Embedding provider ----------------------------------------------
# Powers the Knowledge Base, findSimilarContent, findCommonMistakes, and
# findBrandGuidance. Active provider/model is read from the `settings` row
# (set via Settings → Research → Embedding provider) at runtime; the env
# vars below are an optional per-process override that bypasses the DB.
#
# Providers: gemini | openai (voyage is catalogued but not wired — needs a
# 1024d DB column migration). All wired models output 1536d to match the
# `embeddings.embedding` column.
#
# When provider = gemini → requires GEMINI_API_KEY.
# When provider = openai → requires OPENAI_API_KEY with active billing.
#
# After switching providers, re-embed existing rows so search picks them up
# (the read side filters by `embeddings.model`):
#   curl -X POST http://localhost:3000/api/admin/embeddings/backfill
EMBEDDING_PROVIDER=
EMBEDDING_MODEL=


# --- [CHAT] Slack -----------------------------------------------------------
# Slack app: api.slack.com/apps → Create New App.
# Scopes: app_mentions:read, chat:write, commands, users:read, views:open
# Enable Socket Mode → generate App-Level Token with connections:write.
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=


# --- [CHAT] Discord ---------------------------------------------------------
# discord.com/developers → New Application.
# Bot tab → reset token. OAuth2 → bot + applications.commands scopes.
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
# Guild ID for slash-command registration (one server during dev).
DISCORD_GUILD_ID=


# --- [CHANNEL: linkedin] ----------------------------------------------------
# LinkedIn Marketing API access required (1–4 week approval).
# Org URN format: "urn:li:organization:12345"
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORGANIZATION_URN=


# --- [CHANNEL: x] -----------------------------------------------------------
# X/Twitter Basic tier or higher. Generate at developer.x.com → Projects → Keys.
X_API_KEY=
X_API_KEY_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
# Optional. App-only bearer token used by the researcher's x_read_profile tool
# for reading public timelines. If unset, falls back to OAuth1 user-context
# auth with the keys above.
X_BEARER_TOKEN=


# --- [CHANNEL: instagram + facebook] ----------------------------------------
# Meta Graph API. Both channels share a long-lived Page access token (IG
# Business inherits permissions via the linked FB Page).
#
# Setup: developers.facebook.com → create App (Business type) → add the
# Facebook Login product → request `pages_manage_posts`, `pages_read_engagement`,
# `instagram_basic`, `instagram_content_publish`. App Review is required before
# the token works on a Page you don't own. IG account must be Business/Creator
# and linked to the FB Page.
META_PAGE_ACCESS_TOKEN=
META_GRAPH_API_VERSION=v21.0
# Find via: GET /me/accounts (returns the Page id + token) for the page you
# admin; then GET /{page-id}?fields=instagram_business_account for the IG id.
FB_PAGE_ID=
IG_BUSINESS_ACCOUNT_ID=


# --- [CHANNEL: email] — pick HubSpot OR Mailchimp ---------------------------

# HubSpot — Settings → Integrations → Private Apps → create app.
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_PORTAL_ID=
HUBSPOT_DEFAULT_LIST_ID=

# Mailchimp — Account → Extras → API keys.
# Server prefix is the suffix after the dash in your API key (e.g. "us1").
MAILCHIMP_API_KEY=
MAILCHIMP_SERVER_PREFIX=
MAILCHIMP_DEFAULT_LIST_ID=
MAILCHIMP_FROM_EMAIL=
MAILCHIMP_FROM_NAME=


# --- [CHANNEL: assets] ------------------------------------------------------
# Default image + video pipeline now uses GEMINI_API_KEY directly (Nano Banana
# 2 + Veo 3.1). Replicate is kept as a fallback for SDXL / Flux / the legacy
# Replicate-hosted Nano Banana — only required if you select one of those
# models in admin Settings → Image generation model.
REPLICATE_API_TOKEN=
# Bannerbear — bannerbear.com → Project Settings.
BANNERBEAR_API_KEY=
# Placid — placid.app → API tab.
PLACID_API_TOKEN=
# Poster template UID. When set together with one of the keys above, the
# legacy variant pipeline switches to two-stage rendering: model generates a
# clean BACKGROUND only, then the template composites the real title text
# and the real brand logo on top. Template must expose layers named
# "background" (image), "title" (text), and "logo" (image). Per-channel
# overrides win over the generic one (e.g. POSTER_TEMPLATE_ID_LINKEDIN).
POSTER_TEMPLATE_ID=
POSTER_TEMPLATE_ID_LINKEDIN=
POSTER_TEMPLATE_ID_X_POST=
POSTER_TEMPLATE_ID_X_THREAD=
POSTER_TEMPLATE_ID_BLOG=
POSTER_TEMPLATE_ID_EMAIL=


# --- [CHANNEL: ga4] ---------------------------------------------------------
# GCP Console → IAM → Service Accounts → create + download JSON key.
# Grant "Viewer" on the GA4 property.
GA4_PROPERTY_ID=
# Full GCP service-account JSON (raw stringified JSON, single line).
GA4_SERVICE_ACCOUNT_JSON=


# --- [RESEARCH] Daily news scan --------------------------------------------
# The Researcher's daily cron picks one of these two providers (toggle in
# Settings → Research). At least one key must be set for the cron to do
# anything useful; an unset key surfaces as a tool error in the report.
#
# Tavily: signup at tavily.com — 1k free calls/month, returns answers +
# extracted page content per result.
TAVILY_API_KEY=
# Brave Search: signup at api.search.brave.com — 2k free queries/month,
# independent web index (not a Bing/Google reseller).
BRAVE_SEARCH_API_KEY=


# --- [OPS] Reporting --------------------------------------------------------
# Slack / Discord channel ID for the weekly Analyst cron report.
MARKETING_SLACK_CHANNEL_ID=
MARKETING_DISCORD_CHANNEL_ID=


# --- [OPS] Observability ----------------------------------------------------
# Grafana Cloud OTLP endpoint + auth header.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=marketing-agent

# Slack incoming-webhook URL for ops alerts (LLM preflight failures, quota
# exhaustion, rate-limit / auth failures during workflow runs). Slack:
# api.slack.com/messaging/webhooks. Leave unset to log to stderr instead.
OPS_ALERT_WEBHOOK_URL=
